@inject FilamentService FilamentService
@inject PrinterStatusStore PrinterStatusStore
@using FilamentTracker.Models
@implements IDisposable

<section>
    <div class="pageHeader">
        <h1>🖨️ Live Printers</h1>
        <div class="sub">Real-time status for all configured printers</div>
    </div>

    @if (_isLoading)
    {
        <div class="printerStatusGrid">
            @for (var i = 0; i < 3; i++)
            {
                <LoadingSkeleton />
            }
        </div>
    }
    else if (!_printers.Any())
    {
        <div class="formCard" style="padding: 40px;">
            <EmptyState Icon="🖨️" Title="No printers configured" Message="Add printers in the MQTT page to see live status here." />
        </div>
    }
    else
    {
        <div class="printerStatusGrid">
            @foreach (var printer in _printers.Where(p => p.Enabled))
            {
                var status = _printerStatuses.GetValueOrDefault(printer.Id);
                var isConnected = PrinterStatusStore.IsPrinterConnected(printer.Id);

                <PrinterStatusCard
                    Printer="printer"
                    Status="status"
                    IsConnected="isConnected"
                    Compact="false"
                    ShowLocation="true"
                    EtaText="@(status?.TimeRemaining ?? "--:--")" />
            }
        </div>

        @if (_printers.Any(p => !p.Enabled))
        {
            <div style="margin-top: 12px; font-size: 13px; color: var(--muted); text-align: center;">
                @_printers.Count(p => !p.Enabled) disabled printer(s) not shown — enable them in MQTT settings.
            </div>
        }
    }
</section>

@code {
    private List<Printer> _printers = new();
    private Dictionary<int, PrintStatus> _printerStatuses = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        PrinterStatusStore.OnStatusChanged += HandleStatusUpdate;
        _printers = await FilamentService.GetAllPrintersAsync();
        _printerStatuses = PrinterStatusStore.GetAllStatuses();
        _isLoading = false;
    }

    private void HandleStatusUpdate(int printerId, PrintStatus status)
    {
        try
        {
            _printerStatuses[printerId] = status;
            InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
            // Ignore UI update race during component disposal.
        }
    }

    public void Dispose()
    {
        PrinterStatusStore.OnStatusChanged -= HandleStatusUpdate;
    }
}
