@inject ThemeService ThemeService
@inject FilamentService FilamentService
@inject CsvService CsvService
@inject ThresholdService ThresholdService
@inject BambuLabService BambuLabService
@inject IJSRuntime Js
@using System.Text
@using FilamentTracker.Models
@implements IDisposable

<section>
    <div class="pageHeader">
        <h1>Settings</h1>
        <div class="sub">Customize your experience and manage your data</div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="strip"
             style="margin-top: 14px; @(_messageIsError ? "border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12);" : "border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.12);")">
            <div>@_message</div>
        </div>
    }

    <div class="formCard">
        <h2 style="margin-top: 0;">🎨 Appearance</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Switch between dark and light modes based on your preference.
        </div>
        <div class="row">
            <button class="btn @(ThemeService.IsDarkMode ? "primary" : "")" @onclick="() => SetTheme(true)">
                🌙 Dark Mode
            </button>
            <button class="btn @(!ThemeService.IsDarkMode ? "primary" : "")" @onclick="() => SetTheme(false)">
                ☀️ Light Mode
            </button>
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">💱 Currency Settings</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Select your preferred currency for all calculations and displays.
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Currency</label>
            <select class="input" @bind="_selectedCurrency">
                <option value="DKK">DKK - Danish Krone</option>
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="SEK">SEK - Swedish Krona</option>
                <option value="NOK">NOK - Norwegian Krone</option>
                <option value="CHF">CHF - Swiss Franc</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="CNY">CNY - Chinese Yuan</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="NZD">NZD - New Zealand Dollar</option>
                <option value="SGD">SGD - Singapore Dollar</option>
                <option value="HKD">HKD - Hong Kong Dollar</option>
                <option value="INR">INR - Indian Rupee</option>
                <option value="KRW">KRW - South Korean Won</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="BRL">BRL - Brazilian Real</option>
                <option value="ZAR">ZAR - South African Rand</option>
                <option value="PLN">PLN - Polish Złoty</option>
                <option value="CZK">CZK - Czech Koruna</option>
                <option value="HUF">HUF - Hungarian Forint</option>
                <option value="RON">RON - Romanian Leu</option>
                <option value="TRY">TRY - Turkish Lira</option>
            </select>
        </div>
        <button class="btn primary" @onclick="SaveCurrency" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Currency</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">⚖️ Stock Thresholds</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Configure when filaments should be marked as "Low" or "Critical" based on weight remaining.
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Low Threshold (grams)</label>
            <input type="number" class="input" @bind="_lowThreshold" @bind:event="oninput" min="1" max="10000"
                   step="50"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Filaments below this weight will be marked as "Low" (yellow warning)
            </div>
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Critical Threshold (grams)</label>
            <input type="number" class="input" @bind="_criticalThreshold" @bind:event="oninput" min="1" max="10000"
                   step="50"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Filaments below this weight will be marked as "Critical" (red alert)
            </div>
        </div>
        <button class="btn primary" @onclick="SaveThresholds" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Thresholds</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🖨️ BambuLab MQTT Live Tracking</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Connect to your BambuLab printer to see live print status in the navigation bar.
        </div>

        <div class="checkRow" style="margin-bottom: 16px;">
            <input type="checkbox" @bind="_bambuLabEnabled" id="bambuLabEnabled"/>
            <label for="bambuLabEnabled">Enable BambuLab Live Tracking</label>
        </div>

        <div class="checkRow" style="margin-bottom: 8px;">
            <input type="checkbox" @bind="_amsAutoUpdateWeight" id="amsAutoUpdateWeight" disabled="@(!_bambuLabEnabled)"/>
            <label for="amsAutoUpdateWeight" style="@(!_bambuLabEnabled ? "color: var(--muted);" : "")">
                Auto-update spool weight from AMS
            </label>
        </div>
        <div style="font-size: 12px; color: var(--muted); margin-bottom: 10px; margin-left: 26px;">
            When enabled, the remaining weight on a spool is automatically updated whenever the AMS
            reports a new remaining % — but <strong>only</strong> for spools you have tagged in the AMS page.
            The weight is calculated as: <em>AMS% × spool total weight</em>.
        </div>

        <div class="checkRow" style="margin-bottom: 4px; margin-left: 20px;">
            <input type="checkbox" @bind="_amsAutoUpdateOnlyDecrease" id="amsAutoUpdateOnlyDecrease"
                   disabled="@(!_bambuLabEnabled || !_amsAutoUpdateWeight)"/>
            <label for="amsAutoUpdateOnlyDecrease"
                   style="@(!_bambuLabEnabled || !_amsAutoUpdateWeight ? "color: var(--muted);" : "")">
                Only decrease weight (never add back)
            </label>
        </div>
        <div style="font-size: 12px; color: var(--muted); margin-bottom: 16px; margin-left: 46px;">
            <strong>Checked (recommended for normal use):</strong> The AMS can only reduce weight — it will never increase it.
            Safe when you trust your manually entered values.<br/>
            <strong>Unchecked (two-way sync):</strong> The AMS value always wins in both directions.
            Useful if you accidentally registered usage on the wrong spool —
            once you link the correct spool in the AMS page, the AMS will restore the weight to what it reports.
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Printer IP Address</label>
            <input type="text" class="input" @bind="_bambuLabIpAddress" placeholder="192.168.1.100"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Find this in your printer's network settings
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Access Code</label>
            <input type="text" class="input" @bind="_bambuLabAccessCode" placeholder="12345678" maxlength="8"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Found in Settings → Network → Access Code on your printer
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Serial Number</label>
            <input type="text" class="input" @bind="_bambuLabSerialNumber" placeholder="01S00C..."/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Found in Settings → Device on your printer
            </div>
        </div>

        @if (_bambuLabConnectionStatus != null)
        {
            <div class="strip"
                 style="margin-bottom: 16px; @(_bambuLabConnectionSuccess ? "border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.12);" : "border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12);")">
                <div>@_bambuLabConnectionStatus</div>
            </div>
        }

        <div class="row">
            <button class="btn primary" @onclick="SaveBambuLabSettings" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <text>Saving...</text>
                }
                else
                {
                    <text>💾 Save & Connect</text>
                }
            </button>

            @if (_bambuLabEnabled && BambuLabService.IsConnected)
            {
                <button class="btn" @onclick="DisconnectBambuLab" disabled="@_isProcessing">
                    🔌 Disconnect
                </button>
            }

            @if (_bambuLabEnabled && !string.IsNullOrEmpty(_bambuLabIpAddress))
            {
                <button class="btn" @onclick="TestBambuLabConnection" disabled="@_isProcessing">
                    🧪 Test Connection
                </button>
            }
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📡 MQTT Message Log</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Live feed of the last 50 incoming MQTT messages from your BambuLab printer.
        </div>

        <div style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center; flex-wrap: wrap;">
            <button class="btn" @onclick="RefreshMqttLog">🔄 Refresh</button>
            <button class="btn" @onclick="ClearMqttDisplay">🗑️ Clear Display</button>
            <button class="btn" @onclick="SaveMqttLogCsv">💾 Save Log (CSV)</button>
            <button class="btn" @onclick="SaveServerMqttLog">📥 Save Server Log</button>
            @if (BambuLabService.IsConnected)
            {
                <span style="font-size: 12px; color: #10b981;">● Connected</span>
            }
            else
            {
                <span style="font-size: 12px; color: var(--muted);">○ Not connected</span>
            }
            <div style="margin-left: auto; font-size: 12px; color: var(--muted);">
                Messages: <strong>@_mqttLogEntries.Count</strong>
                @if (_mqttLogEntries.Any())
                {
                    <span> · Last: <strong>@_mqttLogEntries.Last().Timestamp.ToString("HH:mm:ss")</strong></span>
                }
            </div>
        </div>

        <div id="mqttTerminal" style="
            background: #0d1117;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 14px 16px;
            height: 400px;
            overflow-y: auto;
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            line-height: 1.6;
            color: #e6edf3;
        ">
            @if (!_mqttLogEntries.Any())
            {
                <div style="color: #6e7681; text-align: center; padding-top: 160px;">
                    No messages yet. Connect to your printer to see live data.
                </div>
            }
            else
            {
                @foreach (var entry in _mqttLogEntries.AsEnumerable().Reverse())
                {
                    <div
                        style="margin-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 6px;">
                        <span style="color: #58a6ff; user-select: none;">[@entry.Timestamp.ToString("HH:mm:ss")]</span>
                        <span style="color: #3fb950; user-select: none;"> device/report </span>
                        <span style="color: #e6edf3; word-break: break-all;">@entry.Payload</span>
                    </div>
                }
            }
        </div>
        <div style="font-size: 11px; color: var(--muted); margin-top: 8px;">
            Showing last @_mqttLogEntries.Count message(s) — auto-updates when connected.
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📤 Export Data</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Download all your filament data as a CSV file for backup or analysis.
        </div>
        <button class="btn primary" @onclick="ExportData" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Exporting...</text>
            }
            else
            {
                <text>📥 Export to CSV</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📥 Import Data</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Upload a CSV file to import filament data. The CSV should have the following columns:
            Brand, Type, Finish, Color Name, Color Code, Total Weight (g), Weight Remaining (g),
            Quantity, Spool Type, Spool Material, Reusable Spool, Diameter (mm), Location, Notes, Date Added, Purchase
            Price Per Kg
        </div>
        <div style="margin-bottom: 16px;">
            <button class="btn" @onclick="DownloadTemplate" disabled="@_isProcessing">
                📄 Download CSV Template
            </button>
        </div>
        <div class="row">
            <InputFile OnChange="HandleFileSelected" class="input" style="flex: initial;" accept=".csv"
                       disabled="@_isProcessing"/>
            <button class="btn primary" @onclick="ImportData" disabled="@(_selectedFile == null || _isProcessing)">
                @if (_isProcessing)
                {
                    <text>Importing...</text>
                }
                else
                {
                    <text>📤 Import CSV</text>
                }
            </button>
        </div>
        @if (_selectedFile != null)
        {
            <div style="margin-top: 8px; color: var(--muted); font-size: 12px;">
                Selected: @_selectedFile.Name (@(_selectedFile.Size / 1024.0)KB)
            </div>
        }
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🏷️ Manage Brands</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Manage the brands that appear in the Brand dropdown when adding filaments.
        </div>

        <div class="spoolList" style="max-height: 300px; overflow-y: auto; margin-bottom: 16px;">
            @if (_brands.Any())
            {
                @foreach (var brand in _brands)
                {
                    <div class="spoolRow">
                        <div class="left">
                            <div class="title">@brand.Name</div>
                            <div class="subline">Added @brand.DateAdded.ToString("MMM dd, yyyy")</div>
                        </div>
                        <div class="right">
                            <button class="tinyBtn danger" @onclick="() => DeleteBrand(brand.Id)">Delete</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="color: var(--muted); text-align: center; padding: 20px;">
                    No brands yet. Add your first brand using the "Add Filament" page!
                </p>
            }
        </div>

        <div style="font-size: 12px; color: var(--muted);">
            <strong>Tip:</strong> Use the "Other (Add Custom)" option in the Brand dropdown on the Add Filament page
            to add new brands. They will automatically appear here and in the dropdown for future use.
        </div>
    </div>

    <div class="formCard" style="border-color: rgba(239,68,68,.40);">
        <h2 style="margin-top: 0; color: var(--danger);">⚠️ Danger Zone</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            <strong>Warning:</strong> This action will permanently delete ALL filament data from the database.
            This cannot be undone! Make sure to export your data first if you need it.
        </div>

        @if (!_showPurgeConfirm)
        {
            <button class="btn danger" @onclick="() => _showPurgeConfirm = true" disabled="@_isProcessing">
                🗑️ Purge Database
            </button>
        }
        else
        {
            <div class="panel"
                 style="background: rgba(239,68,68,.10); border-color: rgba(239,68,68,.35); padding: 16px;">
                <div style="font-weight: 900; margin-bottom: 12px;">
                    Are you absolutely sure?
                </div>
                <div style="color: var(--muted); margin-bottom: 16px; font-size: 14px;">
                    This will delete ALL @_filamentCount filament(s) and @_spoolCount spool(s) from your database.
                    This action cannot be undone!
                </div>
                <div class="row">
                    <button class="btn danger" @onclick="PurgeDatabase" disabled="@_isProcessing">
                        @if (_isProcessing)
                        {
                            <text>Deleting...</text>
                        }
                        else
                        {
                            <text>Yes, Delete Everything</text>
                        }
                    </button>
                    <button class="btn" @onclick="() => _showPurgeConfirm = false">
                        Cancel
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">ℹ️ About</h2>
        <div style="color: var(--muted); line-height: 1.6;">
            <p><strong>Filament Tracker v2.0</strong></p>
            <p>
                A comprehensive filament inventory management system for 3D printing enthusiasts.
                Track your filaments, manage spools, monitor usage, and never run out unexpectedly.
            </p>
            <p style="margin-top: 16px;">
                <strong>Features:</strong>
            </p>
            <ul>
                <li>Multi-spool filament tracking</li>
                <li>Low stock warnings</li>
                <li>Reusable spool management</li>
                <li>CSV import/export</li>
                <li>Dark/Light themes</li>
                <li>Advanced filtering and search</li>
            </ul>
            <p style="margin-top: 16px;">
                <strong>Database:</strong> SQLite<br/>
                <strong>Framework:</strong> Blazor Server (.NET 8)<br/>
                <strong>Storage:</strong> Local file-based database
            </p>
        </div>
    </div>
</section>

@code {
    private IBrowserFile? _selectedFile;
    private bool _isProcessing;
    private bool _showPurgeConfirm;
    private string _message = "";
    private bool _messageIsError;
    private int _filamentCount;
    private int _spoolCount;
    private List<Brand> _brands = new();
    private int _lowThreshold = 500;
    private int _criticalThreshold = 250;
    private string _selectedCurrency = "DKK";

    // BambuLab settings
    private bool _bambuLabEnabled;
    private bool _amsAutoUpdateWeight;
    private bool _amsAutoUpdateOnlyDecrease = true;
    private string _bambuLabIpAddress = "";
    private string _bambuLabAccessCode = "";
    private string _bambuLabSerialNumber = "";
    private string? _bambuLabConnectionStatus;
    private bool _bambuLabConnectionSuccess;

    // MQTT log terminal
    private List<MqttLogEntry> _mqttLogEntries = new();

    protected override async Task OnInitializedAsync()
    {
        await UpdateCounts();
        await LoadBrands();
        await LoadThresholds();
        RefreshMqttLog();
        BambuLabService.OnMqttMessageLogged += OnNewMqttMessage;
    }

    public void Dispose()
    {
        BambuLabService.OnMqttMessageLogged -= OnNewMqttMessage;
    }

    private void OnNewMqttMessage(MqttLogEntry entry)
    {
        try
        {
            InvokeAsync(() =>
            {
                try
                {
                    _mqttLogEntries = BambuLabService.GetMqttLog().ToList();
                    StateHasChanged();
                }
                catch
                {
                    /* component may have been disposed */
                }
            });
        }
        catch
        {
            /* swallow to protect the MQTT background thread */
        }
    }

    private void RefreshMqttLog()
    {
        _mqttLogEntries = BambuLabService.GetMqttLog().ToList();
        StateHasChanged();
    }

    private void ClearMqttDisplay()
    {
        _mqttLogEntries = new List<MqttLogEntry>();
        StateHasChanged();
    }

    private async Task SaveMqttLogCsv()
    {
        try
        {
            var entries = BambuLabService.GetMqttLog().ToList();
            if (!entries.Any())
            {
                ShowMessage("No MQTT messages to save yet.", true);
                return;
            }

            var sb = new StringBuilder();
            sb.AppendLine("Timestamp,Payload");
            foreach (var e in entries)
            {
                var ts = e.Timestamp.ToString("o");
                var escaped = (e.Payload).Replace("\"", "\"\"");
                sb.AppendLine($"\"{ts}\",\"{escaped}\"");
            }

            var bytes = Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"mqtt-log-{DateTime.Now:yyyy-MM-dd_HH-mm-ss}.csv";
            await Js.InvokeVoidAsync("downloadFile", fileName, base64);
            ShowMessage($"Saved {entries.Count} MQTT message(s) to {fileName}", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving MQTT log: {ex.Message}", true);
        }
    }

    private async Task SaveServerMqttLog()
    {
        try
        {
            var content = await BambuLabService.GetServerMqttLogAsync();
            if (string.IsNullOrEmpty(content))
            {
                ShowMessage("Server log is empty or does not exist yet.", true);
                return;
            }

            var bytes = Encoding.UTF8.GetBytes(content);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"bambulab-server-log-{DateTime.Now:yyyy-MM-dd_HH-mm-ss}.txt";
            await Js.InvokeVoidAsync("downloadFile", fileName, base64);
            ShowMessage($"Saved server log to {fileName}", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving server log: {ex.Message}", true);
        }
    }

    private async Task LoadThresholds()
    {
        var settings = await FilamentService.GetSettingsAsync();
        _lowThreshold = (int)settings.LowThreshold;
        _criticalThreshold = (int)settings.CriticalThreshold;
        _selectedCurrency = settings.Currency;

        // Load BambuLab settings
        _bambuLabEnabled = settings.BambuLabEnabled;
        _amsAutoUpdateWeight = settings.AmsAutoUpdateWeight;
        _amsAutoUpdateOnlyDecrease = settings.AmsAutoUpdateOnlyDecrease;
        _bambuLabIpAddress = settings.BambuLabIpAddress ?? "";
        _bambuLabAccessCode = settings.BambuLabAccessCode ?? "";
        _bambuLabSerialNumber = settings.BambuLabSerialNumber ?? "";
    }

    private async Task SaveCurrency()
    {
        try
        {
            _isProcessing = true;
            StateHasChanged();

            var settings = await FilamentService.GetSettingsAsync();
            settings.Currency = _selectedCurrency;

            await FilamentService.UpdateSettingsAsync(settings);

            ShowMessage("Currency saved successfully!", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving currency: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SaveThresholds()
    {
        try
        {
            // Validate thresholds
            if (_criticalThreshold >= _lowThreshold)
            {
                ShowMessage("Critical threshold must be less than Low threshold", true);
                return;
            }

            if (_criticalThreshold < 1 || _lowThreshold < 1)
            {
                ShowMessage("Thresholds must be greater than 0", true);
                return;
            }

            _isProcessing = true;
            StateHasChanged();

            var settings = await FilamentService.GetSettingsAsync();
            settings.LowThreshold = _lowThreshold;
            settings.CriticalThreshold = _criticalThreshold;

            await FilamentService.UpdateSettingsAsync(settings);
            ThresholdService.SetThresholds(_lowThreshold, _criticalThreshold);

            ShowMessage("Thresholds saved successfully! Changes apply immediately.", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving thresholds: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task LoadBrands()
    {
        _brands = await FilamentService.GetBrandsAsync();
    }

    private async Task DeleteBrand(int brandId)
    {
        try
        {
            await FilamentService.DeleteBrandAsync(brandId);
            await LoadBrands();
            ShowMessage("Brand deleted successfully", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error deleting brand: {ex.Message}", true);
        }
    }

    private async Task UpdateCounts()
    {
        var filaments = await FilamentService.GetAllFilamentsAsync();
        _filamentCount = filaments.Count;
        _spoolCount = filaments.Sum(f => f.SpoolCount);
    }

    private void SetTheme(bool isDark)
    {
        ThemeService.SetDarkMode(isDark);
        ShowMessage($"Theme changed to {(isDark ? "Dark" : "Light")} mode", false);
    }

    private async Task DownloadTemplate()
    {
        try
        {
            var template = "Brand,Type,Finish,Color Name,Color Code,Total Weight (g),Weight Remaining (g),Quantity,Spool Type,Spool Material,Reusable Spool,Diameter (mm),Location,Notes,Date Added,Purchase Price Per Kg\n" +
                           "Bambu Lab,PLA,Matte,Example Color,#FF0000,1000,1000,1,spool,plastic,Yes,1.75,Shelf A,Example notes,02/18/2026,149";

            var bytes = Encoding.UTF8.GetBytes(template);
            var base64 = Convert.ToBase64String(bytes);

            await Js.InvokeVoidAsync("downloadFile", "filament-template.csv", base64);

            ShowMessage("Template downloaded successfully!", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error downloading template: {ex.Message}", true);
        }
    }

    private async Task ExportData()
    {
        try
        {
            _isProcessing = true;
            StateHasChanged();

            var csv = await CsvService.ExportToCsvAsync();
            var fileName = $"filament-inventory-{DateTime.Now:yyyy-MM-dd}.csv";

            var bytes = Encoding.UTF8.GetBytes(csv);
            var base64 = Convert.ToBase64String(bytes);

            await Js.InvokeVoidAsync("downloadFile", fileName, base64);

            ShowMessage($"Successfully exported {_filamentCount} filament(s) to {fileName}", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error exporting data: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
    }

    private async Task ImportData()
    {
        if (_selectedFile == null) return;

        try
        {
            _isProcessing = true;
            StateHasChanged();

            await using var stream = _selectedFile.OpenReadStream(10 * 1024 * 1024); // 10MB max
            using var reader = new StreamReader(stream);
            var csv = await reader.ReadToEndAsync();

            await CsvService.ImportFromCsvAsync(csv);
            await UpdateCounts();

            ShowMessage($"Successfully imported filaments from {_selectedFile.Name}", false);
            _selectedFile = null;
        }
        catch (Exception ex)
        {
            ShowMessage($"Error importing data: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task PurgeDatabase()
    {
        try
        {
            _isProcessing = true;
            StateHasChanged();

            await FilamentService.PurgeDatabaseAsync();
            await UpdateCounts();

            _showPurgeConfirm = false;
            ShowMessage("Database purged successfully. All filament data has been deleted.", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error purging database: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void ShowMessage(string msg, bool isError)
    {
        _message = msg;
        _messageIsError = isError;

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            _message = "";
            InvokeAsync(StateHasChanged);
        });
    }

    // BambuLab MQTT Methods
    private async Task SaveBambuLabSettings()
    {
        try
        {
            _isProcessing = true;
            _bambuLabConnectionStatus = null;
            StateHasChanged();

            var settings = await FilamentService.GetSettingsAsync();
            settings.BambuLabEnabled = _bambuLabEnabled;
            settings.AmsAutoUpdateWeight = _amsAutoUpdateWeight;
            settings.AmsAutoUpdateOnlyDecrease = _amsAutoUpdateOnlyDecrease;
            settings.BambuLabIpAddress = _bambuLabIpAddress;
            settings.BambuLabAccessCode = _bambuLabAccessCode;
            settings.BambuLabSerialNumber = _bambuLabSerialNumber;

            await FilamentService.UpdateSettingsAsync(settings);

            // Propagate the auto-update setting to the live service immediately
            BambuLabService.AmsAutoUpdateWeight = _amsAutoUpdateWeight;
            BambuLabService.AmsAutoUpdateOnlyDecrease = _amsAutoUpdateOnlyDecrease;

            // Connect if enabled
            if (_bambuLabEnabled &&
                !string.IsNullOrEmpty(_bambuLabIpAddress) &&
                !string.IsNullOrEmpty(_bambuLabAccessCode) &&
                !string.IsNullOrEmpty(_bambuLabSerialNumber))
            {
                try
                {
                    await BambuLabService.ConnectAsync(_bambuLabIpAddress, _bambuLabAccessCode, _bambuLabSerialNumber);
                    _bambuLabConnectionStatus = "✅ Successfully connected to BambuLab printer!";
                    _bambuLabConnectionSuccess = true;
                }
                catch (Exception ex)
                {
                    _bambuLabConnectionStatus = $"❌ Connection failed: {ex.Message}";
                    _bambuLabConnectionSuccess = false;
                }
            }
            else if (!_bambuLabEnabled)
            {
                await BambuLabService.DisconnectAsync();
                _bambuLabConnectionStatus = "Settings saved. BambuLab tracking disabled.";
                _bambuLabConnectionSuccess = true;
            }

            ShowMessage("BambuLab settings saved!", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving BambuLab settings: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task TestBambuLabConnection()
    {
        try
        {
            _isProcessing = true;
            _bambuLabConnectionStatus = "Testing connection...";
            StateHasChanged();

            if (string.IsNullOrEmpty(_bambuLabIpAddress) ||
                string.IsNullOrEmpty(_bambuLabAccessCode) ||
                string.IsNullOrEmpty(_bambuLabSerialNumber))
            {
                _bambuLabConnectionStatus = "❌ Please fill in all fields";
                _bambuLabConnectionSuccess = false;
                return;
            }

            await BambuLabService.ConnectAsync(_bambuLabIpAddress, _bambuLabAccessCode, _bambuLabSerialNumber);

            // Wait a moment for the connection to establish
            await Task.Delay(2000);

            if (BambuLabService.IsConnected)
            {
                _bambuLabConnectionStatus = "✅ Connection successful! Receiving data from printer.";
                _bambuLabConnectionSuccess = true;
            }
            else
            {
                _bambuLabConnectionStatus = "❌ Connection failed. Check your settings and network.";
                _bambuLabConnectionSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _bambuLabConnectionStatus = $"❌ Connection failed: {ex.Message}";
            _bambuLabConnectionSuccess = false;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DisconnectBambuLab()
    {
        try
        {
            _isProcessing = true;
            StateHasChanged();

            await BambuLabService.DisconnectAsync();

            _bambuLabConnectionStatus = "Disconnected from printer";
            _bambuLabConnectionSuccess = true;

            ShowMessage("Disconnected from BambuLab printer", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error disconnecting: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

