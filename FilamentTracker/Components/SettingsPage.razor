@inject ThemeService ThemeService
@inject FilamentService FilamentService
@inject CsvService CsvService
@inject ThresholdService ThresholdService
@inject BambuLabService BambuLabService
@inject MqttRelayService MqttRelayService
@inject IJSRuntime Js
@using System.Text
@using FilamentTracker.Models
@implements IDisposable

<section>
    <div class="pageHeader">
        <h1>Settings</h1>
        <div class="sub">Customize your experience and manage your data</div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="strip"
             style="margin-top: 14px; @(_messageIsError ? "border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12);" : "border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.12);")">
            <div>@_message</div>
        </div>
    }

    <div class="formCard">
        <h2 style="margin-top: 0;">🎨 Appearance</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Choose a color theme to personalize your experience.
        </div>
        <div class="themeGrid">
            @foreach (var theme in _themes)
            {
                <button class="themeCard @(ThemeService.ThemeName == theme.Id ? "selected" : "")"
                        @onclick="() => SetTheme(theme.Id)">
                    <div class="themeSwatches">
                        @foreach (var color in theme.Colors)
                        {
                            <div class="themeSwatch" style="background: @color;"></div>
                        }
                    </div>
                    <div class="themeName">@theme.Label</div>
                </button>
            }
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">💱 Currency Settings</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Select your preferred currency for all calculations and displays.
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Currency</label>
            <select class="input" @bind="_selectedCurrency">
                <option value="DKK">DKK - Danish Krone</option>
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="SEK">SEK - Swedish Krona</option>
                <option value="NOK">NOK - Norwegian Krone</option>
                <option value="CHF">CHF - Swiss Franc</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="CNY">CNY - Chinese Yuan</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="NZD">NZD - New Zealand Dollar</option>
                <option value="SGD">SGD - Singapore Dollar</option>
                <option value="HKD">HKD - Hong Kong Dollar</option>
                <option value="INR">INR - Indian Rupee</option>
                <option value="KRW">KRW - South Korean Won</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="BRL">BRL - Brazilian Real</option>
                <option value="ZAR">ZAR - South African Rand</option>
                <option value="PLN">PLN - Polish Złoty</option>
                <option value="CZK">CZK - Czech Koruna</option>
                <option value="HUF">HUF - Hungarian Forint</option>
                <option value="RON">RON - Romanian Leu</option>
                <option value="TRY">TRY - Turkish Lira</option>
            </select>
        </div>
        <button class="btn primary" @onclick="SaveCurrency" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Currency</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🌍 Timezone Settings</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Select your timezone for accurate ETA calculations. Daylight saving time is automatically handled.
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Timezone</label>
            <select class="input" @bind="_selectedTimeZone">
                <optgroup label="Europe">
                    <option value="Europe/Copenhagen">Copenhagen (GMT+1/+2)</option>
                    <option value="Europe/London">London (GMT/BST)</option>
                    <option value="Europe/Paris">Paris (GMT+1/+2)</option>
                    <option value="Europe/Berlin">Berlin (GMT+1/+2)</option>
                    <option value="Europe/Amsterdam">Amsterdam (GMT+1/+2)</option>
                    <option value="Europe/Stockholm">Stockholm (GMT+1/+2)</option>
                    <option value="Europe/Oslo">Oslo (GMT+1/+2)</option>
                    <option value="Europe/Helsinki">Helsinki (GMT+2/+3)</option>
                    <option value="Europe/Rome">Rome (GMT+1/+2)</option>
                    <option value="Europe/Madrid">Madrid (GMT+1/+2)</option>
                    <option value="Europe/Zurich">Zurich (GMT+1/+2)</option>
                    <option value="Europe/Vienna">Vienna (GMT+1/+2)</option>
                    <option value="Europe/Prague">Prague (GMT+1/+2)</option>
                    <option value="Europe/Warsaw">Warsaw (GMT+1/+2)</option>
                    <option value="Europe/Budapest">Budapest (GMT+1/+2)</option>
                    <option value="Europe/Athens">Athens (GMT+2/+3)</option>
                    <option value="Europe/Istanbul">Istanbul (GMT+3)</option>
                </optgroup>
                <optgroup label="Americas">
                    <option value="America/New_York">New York (EST/EDT)</option>
                    <option value="America/Chicago">Chicago (CST/CDT)</option>
                    <option value="America/Denver">Denver (MST/MDT)</option>
                    <option value="America/Los_Angeles">Los Angeles (PST/PDT)</option>
                    <option value="America/Toronto">Toronto (EST/EDT)</option>
                    <option value="America/Vancouver">Vancouver (PST/PDT)</option>
                    <option value="America/Mexico_City">Mexico City (CST/CDT)</option>
                    <option value="America/Sao_Paulo">São Paulo (BRT)</option>
                    <option value="America/Argentina/Buenos_Aires">Buenos Aires (ART)</option>
                </optgroup>
                <optgroup label="Asia & Pacific">
                    <option value="Asia/Tokyo">Tokyo (JST)</option>
                    <option value="Asia/Seoul">Seoul (KST)</option>
                    <option value="Asia/Shanghai">Shanghai (CST)</option>
                    <option value="Asia/Hong_Kong">Hong Kong (HKT)</option>
                    <option value="Asia/Singapore">Singapore (SGT)</option>
                    <option value="Asia/Bangkok">Bangkok (ICT)</option>
                    <option value="Asia/Dubai">Dubai (GST)</option>
                    <option value="Asia/Kolkata">Mumbai/Delhi (IST)</option>
                    <option value="Australia/Sydney">Sydney (AEDT/AEST)</option>
                    <option value="Australia/Melbourne">Melbourne (AEDT/AEST)</option>
                    <option value="Australia/Perth">Perth (AWST)</option>
                    <option value="Pacific/Auckland">Auckland (NZDT/NZST)</option>
                </optgroup>
                <optgroup label="Other">
                    <option value="UTC">UTC (Coordinated Universal Time)</option>
                </optgroup>
            </select>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Used to display print completion times (ETA) in your local time
            </div>
        </div>
        <button class="btn primary" @onclick="SaveTimeZone" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Timezone</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">⚖️ Stock Thresholds</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Configure when filaments should be marked as "Low" or "Critical" based on weight remaining.
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Low Threshold (grams)</label>
            <input type="number" class="input" @bind="_lowThreshold" @bind:event="oninput" min="1" max="10000"
                   step="50"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Filaments below this weight will be marked as "Low" (yellow warning)
            </div>
        </div>
        <div style="margin-bottom: 16px;">
            <label class="label">Critical Threshold (grams)</label>
            <input type="number" class="input" @bind="_criticalThreshold" @bind:event="oninput" min="1" max="10000"
                   step="50"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Filaments below this weight will be marked as "Critical" (red alert)
            </div>
        </div>
        <button class="btn primary" @onclick="SaveThresholds" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Thresholds</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🖨️ BambuLab MQTT Live Tracking</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Connect to your BambuLab printer to see live print status in the navigation bar.
        </div>

        <div class="checkRow" style="margin-bottom: 16px;">
            <input type="checkbox" @bind="_bambuLabEnabled" id="bambuLabEnabled"/>
            <label for="bambuLabEnabled">Enable BambuLab Live Tracking</label>
        </div>

        <div class="checkRow" style="margin-bottom: 8px;">
            <input type="checkbox" @bind="_amsAutoUpdateWeight" id="amsAutoUpdateWeight" disabled="@(!_bambuLabEnabled)"/>
            <label for="amsAutoUpdateWeight" style="@(!_bambuLabEnabled ? "color: var(--muted);" : "")">
                Auto-update spool weight from AMS
            </label>
        </div>
        <div style="font-size: 12px; color: var(--muted); margin-bottom: 10px; margin-left: 26px;">
            When enabled, the remaining weight on a spool is automatically updated whenever the AMS
            reports a new remaining % — but <strong>only</strong> for spools you have tagged in the AMS page.
            The weight is calculated as: <em>AMS% × spool total weight</em>.
        </div>

        <div class="checkRow" style="margin-bottom: 4px; margin-left: 20px;">
            <input type="checkbox" @bind="_amsAutoUpdateOnlyDecrease" id="amsAutoUpdateOnlyDecrease"
                   disabled="@(!_bambuLabEnabled || !_amsAutoUpdateWeight)"/>
            <label for="amsAutoUpdateOnlyDecrease"
                   style="@(!_bambuLabEnabled || !_amsAutoUpdateWeight ? "color: var(--muted);" : "")">
                Only decrease weight (never add back)
            </label>
        </div>
        <div style="font-size: 12px; color: var(--muted); margin-bottom: 16px; margin-left: 46px;">
            <strong>Checked (recommended for normal use):</strong> The AMS can only reduce weight — it will never increase it.
            Safe when you trust your manually entered values.<br/>
            <strong>Unchecked (two-way sync):</strong> The AMS value always wins in both directions.
            Useful if you accidentally registered usage on the wrong spool —
            once you link the correct spool in the AMS page, the AMS will restore the weight to what it reports.
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Printer IP Address</label>
            <input type="text" class="input" @bind="_bambuLabIpAddress" placeholder="192.168.1.100"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Find this in your printer's network settings
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Access Code</label>
            <input type="text" class="input" @bind="_bambuLabAccessCode" placeholder="12345678" maxlength="8"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Found in Settings → Network → Access Code on your printer
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Serial Number</label>
            <input type="text" class="input" @bind="_bambuLabSerialNumber" placeholder="01S00C..."/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Found in Settings → Device on your printer
            </div>
        </div>

        @if (_bambuLabConnectionStatus != null)
        {
            <div class="strip"
                 style="margin-bottom: 16px; @(_bambuLabConnectionSuccess ? "border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.12);" : "border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12);")">
                <div>@_bambuLabConnectionStatus</div>
            </div>
        }

        <div class="row">
            <button class="btn primary" @onclick="SaveBambuLabSettings" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <text>Saving...</text>
                }
                else
                {
                    <text>💾 Save & Connect</text>
                }
            </button>

            @if (_bambuLabEnabled && BambuLabService.IsConnected)
            {
                <button class="btn" @onclick="DisconnectBambuLab" disabled="@_isProcessing">
                    🔌 Disconnect
                </button>
            }

            @if (_bambuLabEnabled && !string.IsNullOrEmpty(_bambuLabIpAddress))
            {
                <button class="btn" @onclick="TestBambuLabConnection" disabled="@_isProcessing">
                    🧪 Test Connection
                </button>
            }
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🔄 MQTT Relay Server</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Enable this to rebroadcast MQTT messages from your printer. Your ESP32 and other devices can connect to this server instead of directly to the printer, reducing load on the printer's MQTT broker.
        </div>

        <div class="checkRow" style="margin-bottom: 16px;">
            <input type="checkbox" @bind="_mqttRelayEnabled" id="mqttRelayEnabled" disabled="@(!_bambuLabEnabled)"/>
            <label for="mqttRelayEnabled" style="@(!_bambuLabEnabled ? "color: var(--muted);" : "")">Enable MQTT Relay Server</label>
        </div>
        @if (!_bambuLabEnabled)
        {
            <div style="font-size: 12px; color: var(--muted); margin-bottom: 16px; margin-left: 26px;">
                ⚠️ BambuLab MQTT must be enabled and connected before the relay can work.
            </div>
        }

        <div style="margin-bottom: 16px;">
            <label class="label">Relay Port</label>
            <input type="number" class="input" @bind="_mqttRelayPort" min="1" max="65535" placeholder="1883"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Default MQTT port is 1883. Change if needed. Make sure this port is not in use.
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Username (Optional)</label>
            <input type="text" class="input" @bind="_mqttRelayUsername" placeholder="Leave empty for no auth"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Optional authentication for clients connecting to the relay
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="label">Password (Optional)</label>
            <input type="password" class="input" @bind="_mqttRelayPassword" placeholder="Leave empty for no auth"/>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
                Required if username is set
            </div>
        </div>

        @if (_mqttRelayStatus != null)
        {
            <div class="strip"
                 style="margin-bottom: 16px; @(_mqttRelayStatusSuccess ? "border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.12);" : "border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12);")">
                <div>@_mqttRelayStatus</div>
            </div>
        }

        <div style="margin-bottom: 16px;">
            <details style="cursor: pointer;">
                <summary style="color: var(--muted); font-size: 13px; padding: 8px 0;">
                    📖 ESP32 Connection Instructions
                </summary>
                <div style="background: rgba(255,255,255,0.03); padding: 12px; border-radius: 8px; margin-top: 8px; font-size: 12px;">
                    <p><strong>Configure your ESP32 to connect to this relay:</strong></p>
                    <pre style="background: #0d1117; padding: 10px; border-radius: 6px; overflow-x: auto;">
const char* mqtt_server = "<strong>@GetServerIpAddress()</strong>";  // This server's IP
const int mqtt_port = @_mqttRelayPort;
@if (!string.IsNullOrEmpty(_mqttRelayUsername))
{
<text>const char* mqtt_user = "@_mqttRelayUsername";
const char* mqtt_pass = "@_mqttRelayPassword";</text>
}
else
{
<text>// No authentication required</text>
}

// Subscribe to the same topic
client.subscribe("device/@(_bambuLabSerialNumber ?? "YOUR_SERIAL")/report");</pre>
                    <p style="margin-top: 10px; color: var(--muted);">
                        <strong>Benefits:</strong> Your ESP32 connects to this server instead of the printer, reducing the number of direct connections to the printer's MQTT broker.
                    </p>
                </div>
            </details>
        </div>

        <button class="btn primary" @onclick="SaveMqttRelaySettings" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Saving...</text>
            }
            else
            {
                <text>💾 Save Relay Settings</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📡 MQTT Message Log</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Live feed of the last 50 incoming MQTT messages from your BambuLab printer.
        </div>

        <div style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center; flex-wrap: wrap;">
            <button class="btn" @onclick="RefreshMqttLog">🔄 Refresh</button>
            <button class="btn" @onclick="ClearMqttDisplay">🗑️ Clear Display</button>
            <button class="btn" @onclick="SaveMqttLogCsv">💾 Save Log (CSV)</button>
            <button class="btn" @onclick="SaveServerMqttLog">📥 Save Server Log</button>
            @if (BambuLabService.IsConnected)
            {
                <span style="font-size: 12px; color: #10b981;">● Connected</span>
            }
            else
            {
                <span style="font-size: 12px; color: var(--muted);">○ Not connected</span>
            }
            <div style="margin-left: auto; font-size: 12px; color: var(--muted);">
                Messages: <strong>@_mqttLogEntries.Count</strong>
                @if (_mqttLogEntries.Any())
                {
                    <span> · Last: <strong>@_mqttLogEntries.Last().Timestamp.ToString("HH:mm:ss")</strong></span>
                }
            </div>
        </div>

        <div id="mqttTerminal" style="
            background: #0d1117;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 14px 16px;
            height: 400px;
            overflow-y: auto;
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            line-height: 1.6;
            color: #e6edf3;
        ">
            @if (!_mqttLogEntries.Any())
            {
                <div style="color: #6e7681; text-align: center; padding-top: 160px;">
                    No messages yet. Connect to your printer to see live data.
                </div>
            }
            else
            {
                @foreach (var entry in _mqttLogEntries.AsEnumerable().Reverse())
                {
                    <div
                        style="margin-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 6px;">
                        <span style="color: #58a6ff; user-select: none;">[@entry.Timestamp.ToString("HH:mm:ss")]</span>
                        <span style="color: #3fb950; user-select: none;"> device/report </span>
                        <span style="color: #e6edf3; word-break: break-all;">@entry.Payload</span>
                    </div>
                }
            }
        </div>
        <div style="font-size: 11px; color: var(--muted); margin-top: 8px;">
            Showing last @_mqttLogEntries.Count message(s) — auto-updates when connected.
        </div>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📤 Export Data</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Download all your filament data as a CSV file for backup or analysis.
        </div>
        <button class="btn primary" @onclick="ExportData" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <text>Exporting...</text>
            }
            else
            {
                <text>📥 Export to CSV</text>
            }
        </button>
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">📥 Import Data</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Upload a CSV file to import filament data. The CSV should have the following columns:
            Brand, Type, Finish, Color Name, Color Code, Total Weight (g), Weight Remaining (g),
            Quantity, Spool Type, Spool Material, Reusable Spool, Diameter (mm), Location, Notes, Date Added, Purchase
            Price Per Kg
        </div>
        <div style="margin-bottom: 16px;">
            <button class="btn" @onclick="DownloadTemplate" disabled="@_isProcessing">
                📄 Download CSV Template
            </button>
        </div>
        <div class="row">
            <InputFile OnChange="HandleFileSelected" class="input" style="flex: initial;" accept=".csv"
                       disabled="@_isProcessing"/>
            <button class="btn primary" @onclick="ImportData" disabled="@(_selectedFile == null || _isProcessing)">
                @if (_isProcessing)
                {
                    <text>Importing...</text>
                }
                else
                {
                    <text>📤 Import CSV</text>
                }
            </button>
        </div>
        @if (_selectedFile != null)
        {
            <div style="margin-top: 8px; color: var(--muted); font-size: 12px;">
                Selected: @_selectedFile.Name (@(_selectedFile.Size / 1024.0)KB)
            </div>
        }
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">🏷️ Manage Brands</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            Manage the brands that appear in the Brand dropdown when adding filaments.
        </div>

        <div class="spoolList" style="max-height: 300px; overflow-y: auto; margin-bottom: 16px;">
            @if (_brands.Any())
            {
                @foreach (var brand in _brands)
                {
                    <div class="spoolRow">
                        <div class="left">
                            <div class="title">@brand.Name</div>
                            <div class="subline">Added @brand.DateAdded.ToString("MMM dd, yyyy")</div>
                        </div>
                        <div class="right">
                            <button class="tinyBtn danger" @onclick="() => DeleteBrand(brand.Id)">Delete</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="color: var(--muted); text-align: center; padding: 20px;">
                    No brands yet. Add your first brand using the "Add Filament" page!
                </p>
            }
        </div>

        <div style="font-size: 12px; color: var(--muted);">
            <strong>Tip:</strong> Use the "Other (Add Custom)" option in the Brand dropdown on the Add Filament page
            to add new brands. They will automatically appear here and in the dropdown for future use.
        </div>
    </div>

    <div class="formCard" style="border-color: rgba(239,68,68,.40);">
        <h2 style="margin-top: 0; color: var(--danger);">⚠️ Danger Zone</h2>
        <div style="color: var(--muted); margin-bottom: 16px;">
            <strong>Warning:</strong> This action will permanently delete ALL filament data from the database.
            This cannot be undone! Make sure to export your data first if you need it.
        </div>

        @if (!_showPurgeConfirm)
        {
            <button class="btn danger" @onclick="() => _showPurgeConfirm = true" disabled="@_isProcessing">
                🗑️ Purge Database
            </button>
        }
        else
        {
            <div class="panel"
                 style="background: rgba(239,68,68,.10); border-color: rgba(239,68,68,.35); padding: 16px;">
                <div style="font-weight: 900; margin-bottom: 12px;">
                    Are you absolutely sure?
                </div>
                <div style="color: var(--muted); margin-bottom: 16px; font-size: 14px;">
                    This will delete ALL @_filamentCount filament(s) and @_spoolCount spool(s) from your database.
                    This action cannot be undone!
                </div>
                <div class="row">
                    <button class="btn danger" @onclick="PurgeDatabase" disabled="@_isProcessing">
                        @if (_isProcessing)
                        {
                            <text>Deleting...</text>
                        }
                        else
                        {
                            <text>Yes, Delete Everything</text>
                        }
                    </button>
                    <button class="btn" @onclick="() => _showPurgeConfirm = false">
                        Cancel
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="formCard">
        <h2 style="margin-top: 0;">ℹ️ About</h2>
        <div style="color: var(--muted); line-height: 1.6;">
            <p><strong>Filament Tracker v2.0</strong></p>
