@using FilamentTracker.Models

<AppCard Class="@($"printerStatusCard {(Compact ? "compact" : "full")}")" style="@($"border-color:{CardBorderColor};")">
    <div class="printerStatusHeader">
        <div class="printerColorDot" style="background: @(Printer.ColorHex ?? "#3b82f6");">
            <HeroIcon Name="printer" Class="@($"printerStateIcon {(IsPrinting ? "printing" : IsConnected ? "connected" : "offline")}")" Title="@StateLabel" />
        </div>
        <div style="flex: 1; min-width: 0;">
            <div class="printerStatusName">@Printer.Name</div>
            @if (ShowLocation && !string.IsNullOrEmpty(Printer.Location))
            {
                <div class="printerStatusLocation">@Printer.Location</div>
            }
        </div>
        <StatusPill Label="@StateLabel" Variant="@StateVariant" />
    </div>

    <div class="printerStatusBody">
        @if (!IsConnected)
        {
            @if (Compact)
            {
                <div class="compactMeta">Not connected</div>
            }
            else
            {
                <EmptyState IconName="printer" Title="Not connected" Message="Connect in MQTT settings" Class="printerEmpty" />
            }
        }
        else if (IsPrinting && Status != null)
        {
            @if (!string.IsNullOrEmpty(Status.CurrentFile) && !Compact)
            {
                <div class="printerFile">@Status.CurrentFile</div>
            }
            <div class="printerProgressHeader">
                <span class="printerProgressPct">@Status.Progress<span style="font-size: 14px;">%</span></span>
                <span class="printerLayer">Layer @Status.CurrentLayer / @Status.TotalLayers</span>
            </div>
            <div class="printerProgressBar">
                <div class="printerProgressFill" style="width: @(Status.Progress)%;"></div>
            </div>

            @if (Compact)
            {
                <div class="compactMetaRow">
                    <span>Bed @Status.BedTemperatureﺡﺍC</span>
                    <span>Nozzle @Status.NozzleTemperatureﺡﺍC</span>
                    <span>Time @Status.TimeRemaining</span>
                    <span>Layer @Status.CurrentLayer/@Status.TotalLayers</span>
                    <span>ETA @EtaText</span>
                </div>
            }
            else
            {
                <div class="printerStatGrid">
                    <div class="printerStatBox"><div class="printerStatLabel">Remaining</div><div class="printerStatValue">@Status.TimeRemaining</div></div>
                    <div class="printerStatBox"><div class="printerStatLabel">ETA</div><div class="printerStatValue">@EtaText</div></div>
                    <div class="printerStatBox"><div class="printerStatLabel">Bed</div><div class="printerStatValue">@Status.BedTemperature<span style="font-size: 12px;">ﺡﺍC</span></div></div>
                    <div class="printerStatBox"><div class="printerStatLabel">Nozzle</div><div class="printerStatValue">@Status.NozzleTemperature<span style="font-size: 12px;">ﺡﺍC</span></div></div>
                </div>
            }
        }
        else if (Status != null)
        {
            @if (Compact)
            {
                <div class="compactMetaRow idle">
                    <span>Bed @Status.BedTemperatureﺡﺍC</span>
                    <span>Nozzle @Status.NozzleTemperatureﺡﺍC</span>
                    <span class="idleSleep">Idle</span>
                </div>
            }
            else
            {
                <div class="printerIdleState">
                    <div class="printerIdleIcon"><HeroIcon Name="printer" Class="printerIdleIconSvg" Title="Idle" /></div>
                    <div class="printerIdleText">Idle</div>
                    <div class="printerIdleTemps">
                        <span>Bed @Status.BedTemperatureﺡﺍC</span>
                        <span>Nozzle @Status.NozzleTemperatureﺡﺍC</span>
                    </div>
                </div>
            }
        }
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired] public Printer Printer { get; set; } = default!;
    [Parameter] public PrintStatus? Status { get; set; }
    [Parameter] public bool IsConnected { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool ShowLocation { get; set; } = true;
    [Parameter] public string EtaText { get; set; } = "--:--";

    private bool IsPrinting => Status?.IsPrinting == true;

    private string CardBorderColor => IsPrinting
        ? "rgba(59, 130, 246, 0.45)"
        : IsConnected
            ? "rgba(16, 185, 129, 0.35)"
            : "var(--border)";

    private string StateLabel => IsPrinting ? "Printing" : IsConnected ? "Idle" : "Offline";
    private string StateVariant => IsPrinting ? "printing" : IsConnected ? "connected" : "offline";
}
