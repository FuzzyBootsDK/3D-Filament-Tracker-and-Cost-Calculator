            _isProcessing = false;
        }
    }

    // MQTT Relay Methods
    private async Task SaveMqttRelaySettings()
    {
        try
        {
            _isProcessing = true;
            _mqttRelayStatus = null;
            StateHasChanged();

            // Validate port
            if (_mqttRelayPort < 1 || _mqttRelayPort > 65535)
            {
                _mqttRelayStatus = "❌ Invalid port number. Must be between 1 and 65535.";
                _mqttRelayStatusSuccess = false;
                _isProcessing = false;
                return;
            }

            // Validate auth: if username is set, password must be set too
            if (!string.IsNullOrEmpty(_mqttRelayUsername) && string.IsNullOrEmpty(_mqttRelayPassword))
            {
                _mqttRelayStatus = "❌ Password is required when username is set.";
                _mqttRelayStatusSuccess = false;
                _isProcessing = false;
                return;
            }

            var settings = await FilamentService.GetSettingsAsync();
            settings.MqttRelayEnabled = _mqttRelayEnabled;
            settings.MqttRelayPort = _mqttRelayPort;
            settings.MqttRelayUsername = string.IsNullOrWhiteSpace(_mqttRelayUsername) ? null : _mqttRelayUsername;
            settings.MqttRelayPassword = string.IsNullOrWhiteSpace(_mqttRelayPassword) ? null : _mqttRelayPassword;

            await FilamentService.UpdateSettingsAsync(settings);

            // Start or stop the relay server
            if (_mqttRelayEnabled && BambuLabService.IsAnyConnected)
            {
                try
                {
                    await MqttRelayService.StopRelayServerAsync(); // Stop first if already running
                    await MqttRelayService.StartRelayServerAsync(_mqttRelayPort, settings.MqttRelayUsername, settings.MqttRelayPassword);

                    _mqttRelayStatus = $"✅ MQTT Relay Server started on port {_mqttRelayPort}! Your ESP32 can now connect to this server.";
                    _mqttRelayStatusSuccess = true;
                }
                catch (Exception ex)
                {
                    _mqttRelayStatus = $"❌ Failed to start relay server: {ex.Message}";
                    _mqttRelayStatusSuccess = false;
                }
            }
            else if (!_mqttRelayEnabled)
            {
                await MqttRelayService.StopRelayServerAsync();
                _mqttRelayStatus = "Settings saved. MQTT Relay disabled.";
                _mqttRelayStatusSuccess = true;
            }
            else if (_mqttRelayEnabled && !BambuLabService.IsAnyConnected)
            {
                _mqttRelayStatus = "⚠️ Settings saved, but relay cannot start until BambuLab MQTT is connected.";
                _mqttRelayStatusSuccess = false;
            }

            ShowMessage("MQTT Relay settings saved!", false);
        }
        catch (Exception ex)
        {
            ShowMessage($"Error saving MQTT Relay settings: {ex.Message}", true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private string GetServerIpAddress()
    {
        try
        {
            var host = System.Net.Dns.GetHostEntry(System.Net.Dns.GetHostName());
            foreach (var ip in host.AddressList)
            {
                if (ip.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork)
                {
                    return ip.ToString();
                }
            }
            return "YOUR_SERVER_IP";
        }
        catch
        {
            return "YOUR_SERVER_IP";
        }
    }

