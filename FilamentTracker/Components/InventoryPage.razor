@using FilamentTracker.Models
@inject FilamentService FilamentService
@inject ThresholdService ThresholdService
@inject BambuLabService BambuLabService
@inject EditStateService EditStateService
@implements IDisposable

<section>
    <div class="pageHeader">
        <h1>Filament Inventory</h1>
        <div class="sub">Track your filament spools • Click to manage • Warning for low stock</div>
    </div>

    <section class="kpis">
        <div class="kpi">
            <div class="label">Total Filaments</div>
            <div class="value">@_statistics.GetValueOrDefault("Total", 0)</div>
        </div>
        <div class="kpi">
            <div class="label">Low Stock</div>
            <div class="value" style="color: var(--warn);">@_statistics.GetValueOrDefault("Low", 0)</div>
        </div>
        <div class="kpi">
            <div class="label">Critical</div>
            <div class="value" style="color: var(--danger);">@_statistics.GetValueOrDefault("Critical", 0)</div>
        </div>
    </section>

    @if (LowStockCount > 0)
    {
        <section class="strip">
            <div class="left">
                <span class="pill @(CriticalCount > 0 ? "danger" : "warn")">
                    @if (CriticalCount > 0)
                    {
                        <text>Critical Stock</text>
                    }
                    else
                    {
                        <text>Low Stock</text>
                    }
                </span>
                <div style="color:var(--text);font-weight:900;">
                    @LowStockCount filament@(LowStockCount != 1 ? "s" : "") running low
                    @if (CriticalCount > 0)
                    {
                        <text> (@CriticalCount critical)</text>
                    }
                </div>
            </div>
            <div class="row">
                <button class="btn" @onclick="ToggleLowFilter">
                    @(_filterLowOnly ? "Show All" : "Show Low")
                </button>
            </div>
        </section>
    }

    <div class="controls">
        <input class="input" placeholder="Search (brand, color, type, finish)..." @bind="_searchText"
               @bind:event="oninput" @bind:after="FilterFilaments"/>
        <select class="input" @bind="_typeFilter" @bind:after="FilterFilaments">
            <option value="all">All Types</option>
            <option value="PLA">PLA</option>
            <option value="PETG">PETG</option>
            <option value="ASA">ASA</option>
            <option value="ABS">ABS</option>
            <option value="TPU">TPU</option>
            <option value="NYLON">NYLON</option>
        </select>
        <select class="input" @bind="_sortOption" @bind:after="FilterFilaments">
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="remainingAsc">Lowest Remaining</option>
            <option value="remainingDesc">Highest Remaining</option>
            <option value="nameAsc">Name A→Z</option>
            <option value="nameDesc">Name Z→A</option>
            <option value="colorDark">Color: Darkest First</option>
            <option value="colorLight">Color: Lightest First</option>
        </select>
        <div class="spacer"></div>
        <span class="pill">@_filteredFilaments.Count items</span>
    </div>

    <section class="grid">
        @foreach (var filament in _filteredFilaments)
        {
            <div class="tile @GetFilamentStatus(filament) @(filament.SpoolCount > 1 ? "stacked" : "")"
                 tabindex="0"
                 @onclick="() => OpenDetail(filament)">


                <div class="swatch" style="background: @filament.ColorCode;">
                    @{
                        var status = GetFilamentStatus(filament);
                        var amsDiscrepancy = GetAmsDiscrepancy(filament);
                    }
                    <div class="badge">
                        @if (status == "critical")
                        {
                            <text>Critical</text>
                        }
                        else if (status == "low")
                        {
                            <text>Low</text>
                        }
                        else
                        {
                            <text>OK</text>
                        }
                    </div>
                    @if (amsDiscrepancy.HasValue)
                    {
                        <div class="amsMismatchBadge"
                             title="AMS reports @amsDiscrepancy.Value.amsRemain% remaining but inventory shows @amsDiscrepancy.Value.inventoryPct% — difference exceeds 5%">
                            ⚠
                        </div>
                    }
                    <div class="brand">@filament.Brand</div>
                    <div class="name">@filament.ColorName</div>
                    <div class="pct">@Math.Round(filament.PercentRemaining, 0)%</div>
                </div>

                <div class="tileBody">
                    <div class="meta">
                        <span class="tag type type-@filament.Type">@filament.Type</span>
                        @if (!string.IsNullOrEmpty(filament.Finish))
                        {
                            <span class="tag finish finish-@filament.Finish">@filament.Finish</span>
                        }
                    </div>

                    <div class="barWrap">
                        <div class="bar @(filament.Status == "ok" ? "" : "low")"
                             style="width: @(Math.Round(filament.PercentRemaining, 0))%"></div>
                    </div>

                    <div class="tileFooter">
                        <span>@Math.Round(filament.WeightRemaining, 0)g / @Math.Round(filament.TotalWeight, 0)g</span>
                    </div>
                </div>
            </div>
        }

        @if (_filteredFilaments.Count == 0)
        {
            <div class="colSpan4" style="text-align: center; padding: 40px; color: var(--muted);">
                No filaments found. Try adjusting your filters or add a new filament.
            </div>
        }
    </section>
</section>

@if (_selectedFilament != null)
{
    <FilamentDetailModal Filament="_selectedFilament" OnClose="CloseDetail" OnUpdate="RefreshData"/>
}

@code {
    private List<Filament> _allFilaments = new();
    private List<Filament> _filteredFilaments = new();
    private Dictionary<string, int> _statistics = new();
    private Filament? _selectedFilament;

    private string _searchText = "";
    private string _typeFilter = "all";
    private string _sortOption = "newest";
    private bool _filterLowOnly;

    // spoolId → AMS-reported remain % (from live MQTT)
    private Dictionary<int, int> _amsRemainBySpoolId = new();

    private int LowStockCount => _statistics.GetValueOrDefault("Low", 0) + _statistics.GetValueOrDefault("Critical", 0);
    private int CriticalCount => _statistics.GetValueOrDefault("Critical", 0);

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
        RebuildAmsMap(BambuLabService.GetCurrentStatus());
        BambuLabService.OnStatusUpdated += HandleStatusUpdated;
        BambuLabService.OnAmsWeightUpdated += HandleAmsWeightUpdated;
    }

    public void Dispose()
    {
        BambuLabService.OnStatusUpdated -= HandleStatusUpdated;
        BambuLabService.OnAmsWeightUpdated -= HandleAmsWeightUpdated;
    }

    private void HandleAmsWeightUpdated()
    {
        // Skip refresh if user is currently editing in the modal
        if (EditStateService.IsEditing)
        {
            return;
        }

        // Reload everything from DB so tile weights, bars and discrepancy badges update
        InvokeAsync(async () =>
        {
            try
            {
                await RefreshData();
            }
            catch { /* disposed */ }
        });
    }

    private void HandleStatusUpdated(PrintStatus status)
    {
        try
        {
            RebuildAmsMap(status);
            InvokeAsync(StateHasChanged);
        }
        catch
        {
            // ignored
        }
    }

    /// Build a lookup of spoolId → AMS remain% using the saved RFID ids on each spool.
    private void RebuildAmsMap(PrintStatus status)
    {
        var map = new Dictionary<int, int>();
        if (status.AMSUnits == null) { _amsRemainBySpoolId = map; return; }

        foreach (var unit in status.AMSUnits)
        foreach (var slot in unit.Slots)
        {
            if (slot.Remain == null) continue;

            // Skip placeholder all-zero UUIDs (non-RFID spools)
            var hasUuid = !string.IsNullOrEmpty(slot.TrayUuid) && slot.TrayUuid.Replace("0", "").Length > 0;
            var hasTag  = !string.IsNullOrEmpty(slot.TagUid)  && slot.TagUid.Replace("0", "").Length > 0;
            if (!hasUuid && !hasTag) continue;

            foreach (var filament in _allFilaments)
            foreach (var spool in filament.Spools ?? new List<Spool>())
            {
                if ((hasUuid && spool.AmsTrayUuid == slot.TrayUuid) ||
                    (hasTag  && spool.AmsTagUid   == slot.TagUid))
                {
                    map[spool.Id] = slot.Remain.Value;
                }
            }
        }

        _amsRemainBySpoolId = map;
    }

    /// Returns (amsRemain%, inventoryPct%) if any spool for this filament has an AMS
    /// discrepancy > 5% relative to the spool's total weight. Returns null if no linked AMS data.
    private (int amsRemain, int inventoryPct)? GetAmsDiscrepancy(Filament filament)
    {
        foreach (var spool in filament.Spools ?? new List<Spool>())
        {
            if (!_amsRemainBySpoolId.TryGetValue(spool.Id, out var amsRemain)) continue;

            // Inventory % = WeightRemaining / TotalWeight * 100
            var totalWeight = (double)(spool.TotalWeight > 0 ? spool.TotalWeight : filament.TotalWeight);
            if (totalWeight <= 0) continue;
            var inventoryPct = (int)Math.Round((double)spool.WeightRemaining / totalWeight * 100.0);

            // Both are already percentages of the same base (total weight = 100%)
            // Discrepancy threshold is 5 percentage points
            if (Math.Abs(amsRemain - inventoryPct) > 5)
                return (amsRemain, inventoryPct);
        }
        return null;
    }

    private async Task RefreshData()
    {
        _allFilaments = await FilamentService.GetAllFilamentsAsync();
        _statistics = await FilamentService.GetStatisticsAsync();
        RebuildAmsMap(BambuLabService.GetCurrentStatus());
        FilterFilaments();
        StateHasChanged();
    }

    private string GetFilamentStatus(Filament filament)
    {
        return ThresholdService.GetStatus(filament.WeightRemaining);
    }

    private void FilterFilaments()
    {
        _filteredFilaments = _allFilaments
            .Where(f =>
            {
                if (!string.IsNullOrWhiteSpace(_searchText))
                {
                    var search = _searchText.ToLower();
                    if (!f.Brand.ToLower().Contains(search) &&
                        !f.ColorName.ToLower().Contains(search) &&
                        !f.Type.ToLower().Contains(search) &&
                        !(f.Finish?.ToLower().Contains(search) ?? false))
                        return false;
                }
                if (_typeFilter != "all" && f.Type != _typeFilter) return false;
                if (_filterLowOnly && GetFilamentStatus(f) == "ok") return false;
                return true;
            })
            .ToList();

        _filteredFilaments = _sortOption switch
        {
            "oldest"        => _filteredFilaments.OrderBy(f => f.DateAdded).ToList(),
            "remainingAsc"  => _filteredFilaments.OrderBy(f => f.WeightRemaining).ToList(),
            "remainingDesc" => _filteredFilaments.OrderByDescending(f => f.WeightRemaining).ToList(),
            "nameAsc"       => _filteredFilaments.OrderBy(f => f.ColorName).ToList(),
            "nameDesc"      => _filteredFilaments.OrderByDescending(f => f.ColorName).ToList(),
            "colorDark"     => _filteredFilaments.OrderBy(f => GetColorBrightness(f.ColorCode)).ToList(),
            "colorLight"    => _filteredFilaments.OrderByDescending(f => GetColorBrightness(f.ColorCode)).ToList(),
            _               => _filteredFilaments.OrderByDescending(f => f.DateAdded).ToList()
        };
    }

    private double GetColorBrightness(string hexColor)
    {
        try
        {
            var hex = hexColor.TrimStart('#');
            if (hex.Length == 3)
                hex = string.Concat(hex[0], hex[0], hex[1], hex[1], hex[2], hex[2]);
            if (hex.Length != 6) return 0;
            var r = Convert.ToInt32(hex.Substring(0, 2), 16);
            var g = Convert.ToInt32(hex.Substring(2, 2), 16);
            var b = Convert.ToInt32(hex.Substring(4, 2), 16);
            return 0.299 * r + 0.587 * g + 0.114 * b;
        }
        catch { return 0; }
    }

    private void ToggleLowFilter()
    {
        _filterLowOnly = !_filterLowOnly;
        FilterFilaments();
    }

    private void OpenDetail(Filament filament) => _selectedFilament = filament;

    private void CloseDetail()
    {
        _selectedFilament = null;
        StateHasChanged(); // Force immediate UI update when modal closes
    }
}
