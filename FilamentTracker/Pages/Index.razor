@page "/"
@inject FilamentService FilamentService
@inject BambuLabService BambuLabService
@inject NavigationManager Navigation
@using FilamentTracker.Models
@implements IDisposable

<PageTitle>Filament Inventory</PageTitle>

<div class="wrap">
    <!-- Top Nav -->
    <div class="topRow">
        <div class="topnav">
            <!-- Navigation buttons container -->
            <div class="navButtons">
                <!-- Row 1 -->
                <button class="navbtn @(currentPage == "inventory" ? "active" : "")"
                        @onclick='() => SetPage("inventory")'>
                    <span class="navicon">📦</span> Inventory
                </button>
                <button class="navbtn @(currentPage == "add" ? "active" : "")" @onclick='() => SetPage("add")'>
                    <span class="navicon">➕</span> Add Filament
                </button>
                <button class="navbtn @(currentPage == "spools" ? "active" : "")" @onclick='() => SetPage("spools")'>
                    <span class="navicon">🔁</span> Spools
                </button>

                <!-- Row 2 -->
                <button class="navbtn @(currentPage == "ams" ? "active" : "")" @onclick='() => SetPage("ams")'>
                    <span class="navicon">🗄️</span> AMS
                </button>
                <button class="navbtn @(currentPage == "calculator" ? "active" : "")"
                        @onclick='() => SetPage("calculator")'>
                    <span class="navicon">🧮</span> Calculator
                </button>
                <button class="navbtn @(currentPage == "mqtt" ? "active" : "")" @onclick='() => SetPage("mqtt")'>
                    <span class="navicon">🖨️</span> MQTT
                </button>

                <!-- Row 3 -->
                <button class="navbtn @(currentPage == "settings" ? "active" : "")"
                        @onclick='() => SetPage("settings")'>
                    <span class="navicon">⚙️</span> Settings
                </button>
                <button class="navbtn @(currentPage == "help" ? "active" : "")" @onclick='() => SetPage("help")'>
                    <span class="navicon">❓</span> Help
                </button>
            </div>

            <style>
                /* Scrolling filename marquee for live activity */
                .scrollingWrap {
                    width: 220px; /* reasonable fixed width in widget */
                    overflow: hidden;
                    white-space: nowrap;
                    display: inline-block;
                    vertical-align: middle;
                }

                .scrollingText {
                    display: inline-block;
                    padding-left: 100%; /* start off-screen to the right */
                    animation: scroll-left 24s linear infinite; /* slowed to half speed */
                }

                @@keyframes scroll-left {
                    0% {
                        transform: translateX(0%);
                    }
                    100% {
                        transform: translateX(-100%);
                    }
                }

                /* Slightly reduce animation on hover to allow reading */
                .scrollingWrap:hover .scrollingText {
                    animation-play-state: paused;
                }

                /* Slightly reduce animation on hover to allow reading */
                .scrollingWrap:hover .scrollingText {
                    animation-play-state: paused;
                }

                /* Small styled boxes for temps and fans */
                .tempGrid {
                    display: grid;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 8px;
                    width: 100%;
                    margin-top: 8px;
                }

                .tempBox {
                    border-radius: 10px;
                    padding: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 8px;
                    min-height: 44px;
                    /* stronger border for contrast */
                    border: 1px solid rgba(255, 255, 255, 0.08);
                    color: var(--text);
                }

                .light .tempBox {
                    border-color: rgba(0, 0, 0, 0.06);
                }

                .tempBox .boxLeft {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                .boxIcon {
                    width: 34px;
                    height: 34px;
                    border-radius: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 18px;
                    color: #fff;
                    /* darker icon background for contrast */
                    background: rgba(0, 0, 0, 0.22);
                }

                .light .boxIcon {
                    background: rgba(0, 0, 0, 0.06);
                }

                .boxLabel {
                    font-size: 12px;
                    color: var(--text);
                    font-weight: 800;
                    opacity: 0.95;
                }

                .boxValue {
                    font-weight: 900;
                    font-size: 15px;
                    color: var(--text);
                }

                /* Per-box color schemes */
                .tempBox.nozzle {
                    background: linear-gradient(135deg, #4f46e5, #7c3aed);
                    border-color: rgba(79, 70, 229, 0.35);
                }

                .tempBox.nozzle .boxIcon {
                    background: rgba(255, 255, 255, 0.12);
                }

                .tempBox.bed {
                    background: linear-gradient(135deg, #10b981, #06b6d4);
                    border-color: rgba(16, 185, 129, 0.28);
                }

                .tempBox.bed .boxIcon {
                    background: rgba(255, 255, 255, 0.08);
                }

                .tempBox.fan {
                    background: linear-gradient(135deg, #f59e0b, #ef4444);
                    border-color: rgba(245, 158, 11, 0.28);
                }

                .tempBox.fan .boxIcon {
                    background: rgba(255, 255, 255, 0.08);
                }

                .light .tempBox.nozzle, .light .tempBox.bed, .light .tempBox.fan {
                    background: var(--panel2);
                }

            </style>
            <style>
                .topRow {
                    display: flex;
                    gap: 12px;
                    align-items: flex-start;
                    margin-bottom: 12px;
                }

                .topRow .topnav {
                    flex: 1 1 auto;
                }

                .topRow .liveTracker {
                    width: 360px;
                    max-width: 40%;
                }

                @@media (max-width: 980px) {
                    .topRow {
                        flex-direction: column;
                    }

                    .topRow .liveTracker {
                        width: 100%;
                        max-width: 100%;
                    }
                }

                /* Live tracker header and compact layout */
                .liveTrackerHeader {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                    padding: 10px 12px;
                    border-bottom: 1px solid var(--border);
                }

                .liveHeaderLeft {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .liveHeaderRight {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .progressRow {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    padding: 10px 12px;
                }

                .progressRow .progressBar {
                    flex: 1;
                    height: 10px;
                    background: rgba(255, 255, 255, 0.06);
                    border-radius: 999px;
                    overflow: hidden;
                    border: 1px solid var(--border);
                }

                .progressRow .progressFill {
                    height: 100%;
                    background: linear-gradient(90deg, rgb(59, 130, 246), rgb(99, 102, 241));
                    transition: width 0.25s ease;
                }

                .progressRow .progressText {
                    min-width: 48px;
                    text-align: right;
                    font-weight: 900;
                    font-size: 14px;
                }

                .liveDetailsGrid {
                    display: grid;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 6px; /* Reduced from 8px */
                    padding: 6px 10px 10px 10px; /* Reduced padding */
                }

                .infoBox {
                    border: 1px solid var(--border);
                    background: rgba(255, 255, 255, 0.03);
                    padding: 6px 8px; /* Reduced from 8px */
                    border-radius: 8px; /* Slightly smaller radius */
                    display: flex;
                    flex-direction: row; /* Changed from column to row for single line */
                    gap: 6px;
                    align-items: center;
                    justify-content: center;
                    text-align: center;
                }

                .light .infoBox {
                    background: var(--panel2);
                }

                .infoLabel {
                    font-size: 12px;
                    color: var(--muted);
                    font-weight: 800;
                    white-space: nowrap; /* Prevent wrapping */
                }

                .infoValue {
                    font-weight: 900;
                    color: var(--text);
                    font-size: 13px; /* Slightly smaller for compactness */
                    white-space: nowrap; /* Prevent wrapping */
                }

                /* ETA section between progress bar and details */
                .etaSection {
                    text-align: center;
                    padding: 8px 10px; /* Reduced from 10px 12px */
                    margin: 6px 0; /* Reduced from 8px 0 */
                    border: 1px solid rgba(59, 130, 246, 0.3);
                    background: rgba(59, 130, 246, 0.08);
                    border-radius: 8px; /* Match other elements */
                }

                .light .etaSection {
                    border-color: rgba(59, 130, 246, 0.4);
                    background: rgba(59, 130, 246, 0.12);
                }

                .etaLabel {
                    font-size: 10px; /* Slightly smaller */
                    color: var(--muted);
                    font-weight: 800;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                .etaTime {
                    font-size: 15px; /* Slightly smaller from 16px */
                    font-weight: 900;
                    color: #3b82f6;
                    margin-top: 3px; /* Reduced from 4px */
                }

                .light .etaTime {
                    color: #2563eb;
                }
            </style>
        </div>

        <!-- Live Tracking Widget -->
        <div class="liveTracker">
            <div class="liveTrackerHeader">
                <div class="liveHeaderLeft">
                    <span class="liveIcon">🖨️</span>
                    <span class="liveTitle">Live Tracking</span>
                </div>
                <div class="liveHeaderRight">
                    @if (isConnected)
                    {
                        <div class="statusIndicator connected">
                            <span class="statusDot"></span>
                            <span>Connected</span>
                            @if (currentPrint != null && !string.IsNullOrEmpty(currentPrint.WifiSignal))
                            {
                                var connBars = GetWifiBars(currentPrint.WifiSignal);
                                <span class="wifiBars connWifi" title="@currentPrint.WifiSignal">
                                <span class="wifiBar @(connBars >= 1 ? "active" : "")"></span>
                                <span class="wifiBar @(connBars >= 2 ? "active" : "")"></span>
                                <span class="wifiBar @(connBars >= 3 ? "active" : "")"></span>
                                <span class="wifiBar @(connBars >= 4 ? "active" : "")"></span>
                                <span class="wifiBar @(connBars >= 5 ? "active" : "")"></span>
                            </span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="statusIndicator disconnected">
                            <span class="statusDot"></span>
                            <span>Disconnected</span>
                        </div>
                    }
                </div>
            </div>

            <div class="liveTrackerBody">
                @if (isConnected && currentPrint is { IsPrinting: true })
                {
                    <div class="progressRow">
                        <div class="progressBar">
                            <div class="progressFill" style="width: @(currentPrint.Progress)%"></div>
                        </div>
                        <div class="progressText">@currentPrint.Progress%</div>
                    </div>

                    <!-- ETA Section -->
                    <div class="etaSection">
                        <div class="etaLabel">🎯 Estimated Completion</div>
                        <div class="etaTime">@GetEstimatedCompletionTime(currentPrint.TimeRemaining)</div>
                    </div>

                    <div class="liveDetailsGrid">
                        <div class="infoBox">
                            <div class="infoLabel">⏱️ Time</div>
                            <div class="infoValue">@currentPrint.TimeElapsed / @currentPrint.TimeRemaining</div>
                        </div>
                        <div class="infoBox">
                            <div class="infoLabel">📏 Layer</div>
                            <div class="infoValue">@currentPrint.CurrentLayer / @currentPrint.TotalLayers</div>
                        </div>
                        <div class="infoBox">
                            <div class="infoLabel">🌡️ Nozzle</div>
                            <div class="infoValue">@currentPrint.NozzleTemperature°C</div>
                        </div>
                        <div class="infoBox">
                            <div class="infoLabel">🛏️ Bed</div>
                            <div class="infoValue">@currentPrint.BedTemperature°C</div>
                        </div>
                    </div>
                }
                else if (isConnected)
                {
                    <div class="idleState">
                        <div class="idleIcon">💤</div>
                        <div class="idleText">Printer Idle</div>
                        @if (currentPrint != null && (currentPrint.NozzleTemperature > 0 || currentPrint.BedTemperature > 0))
                        {
                            <div class="idleTemps">
                                <span class="idleTempItem">🌡️ @currentPrint.NozzleTemperature°C</span>
                                <span class="idleTempItem">🛏️ @currentPrint.BedTemperature°C</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="disconnectedMessage">
                        Configure in Settings
                    </div>
                }
            </div>

        </div>
    </div>
    @if (currentPage == "inventory")
    {
        <InventoryPage/>
    }
    else if (currentPage == "add")
    {
        <AddFilamentPage/>
    }
    else if (currentPage == "spools")
    {
        <SpoolsPage/>
    }
    else if (currentPage == "calculator")
    {
        <PrintCalculatorPage/>
    }
    else if (currentPage == "mqtt")
    {
        <MqttPage/>
    }
    else if (currentPage == "help")
    {
        <HelpPage/>
    }
    else if (currentPage == "settings")
    {
        <SettingsPage/>
    }
    else if (currentPage == "ams")
    {
        <AMSPage/>
    }
</div>

@code {
    private string currentPage = "inventory";
    private bool isConnected;
    private PrintStatus? currentPrint;
    private string _userTimeZoneId = "Europe/Copenhagen";

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to BambuLab status updates (now includes printer ID)
        BambuLabService.OnStatusUpdated += HandleStatusUpdate;

        // Load user's timezone setting
        try
        {
            var settings = await FilamentService.GetSettingsAsync();
            _userTimeZoneId = settings.TimeZoneId;
        }
        catch
        {
            // Fallback to Copenhagen if settings can't be loaded
            _userTimeZoneId = "Europe/Copenhagen";
        }

        // Get initial status from first connected printer or use deprecated method for backward compat
#pragma warning disable CS0618 // Type or member is obsolete
        UpdateStatus(BambuLabService.GetCurrentStatus());
#pragma warning restore CS0618 // Type or member is obsolete
    }

    private void HandleStatusUpdate(int printerId, PrintStatus? status)
    {
        if (status == null) return;

        try
        {
            InvokeAsync(() =>
            {
                try
                {
                    UpdateStatus(status);
                    StateHasChanged();
                }
                catch
                {
                    /* component may have been disposed */
                }
            });
        }
        catch
        {
            /* swallow to protect the MQTT background thread */
        }
    }

    private void UpdateStatus(PrintStatus status)
    {
        isConnected = status.IsConnected;
        currentPrint = status;
    }

    private void SetPage(string page)
    {
        currentPage = page;
    }

    private string TruncateFileName(string fileName)
    {
        if (fileName.Length <= 20)
            return fileName;

        return fileName.Substring(0, 17) + "...";
    }

    private bool IsLongFileName(string fileName)
    {
        if (string.IsNullOrEmpty(fileName)) return false;
        // Treat names longer than 28 characters as long and enable scrolling
        return fileName.Length > 28;
    }

    /// <summary>
    ///     Converts a Wi-Fi signal string like "-59dBm" to a bar count 0-5.
    ///     ≥ -50 → 5, -51.-60 → 4, -61.-70 → 3, -71.-80 → 2, -81.-90 → 1, &lt; -90 → 0
    /// </summary>
    private static int GetWifiBars(string? signal)
    {
        if (string.IsNullOrEmpty(signal)) return 0;
        var numStr = signal.Replace("dBm", "").Trim();
        if (!int.TryParse(numStr, out var dbm)) return 0;
        if (dbm >= -50) return 5;
        if (dbm >= -60) return 4;
        if (dbm >= -70) return 3;
        if (dbm >= -80) return 2;
        if (dbm >= -90) return 1;
        return 0;
    }

    /// <summary>
    ///     Calculates the estimated completion time based on time remaining.
    ///     Parses "2h 34m" format and adds to current time, converting to user's local timezone.
    ///     Automatically handles daylight saving time transitions.
    /// </summary>
    private string GetEstimatedCompletionTime(string timeRemaining)
    {
        if (string.IsNullOrEmpty(timeRemaining))
            return "--:--";

        try
        {
            // Parse format like "2h 34m" or "45m" or "1h 5m"
            var hours = 0;
            var minutes = 0;

            var parts = timeRemaining.ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            foreach (var part in parts)
            {
                if (part.EndsWith("h"))
                {
                    if (int.TryParse(part.Replace("h", ""), out var h))
                        hours = h;
                }
                else if (part.EndsWith("m"))
                {
                    if (int.TryParse(part.Replace("m", ""), out var m))
                        minutes = m;
                }
            }

            // Calculate ETA in server time
            var serverEta = DateTime.Now.AddHours(hours).AddMinutes(minutes);

            // Convert to user's timezone (automatically handles DST)
            TimeZoneInfo userTimeZone;
            try
            {
                userTimeZone = TimeZoneInfo.FindSystemTimeZoneById(_userTimeZoneId);
            }
            catch
            {
                // Fallback to Copenhagen if timezone is invalid
                userTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Europe/Copenhagen");
            }

            var localEta = TimeZoneInfo.ConvertTime(serverEta, userTimeZone);

            // Format as "Today at HH:mm" or "Tomorrow at HH:mm"
            // Compare dates in user's timezone
            var localNow = TimeZoneInfo.ConvertTime(DateTime.Now, userTimeZone);
            var isToday = localEta.Date == localNow.Date;
            var isTomorrow = localEta.Date == localNow.Date.AddDays(1);

            if (isToday)
                return $"Today at {localEta:HH:mm}";
            else if (isTomorrow)
                return $"Tomorrow at {localEta:HH:mm}";
            else
                return localEta.ToString("ddd at HH:mm");
        }
        catch
        {
            return "--:--";
        }
    }

    public void Dispose()
    {
        BambuLabService.OnStatusUpdated -= HandleStatusUpdate;
    }

}
