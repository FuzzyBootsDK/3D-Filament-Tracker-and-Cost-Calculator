@page "/"
@inject FilamentService FilamentService
@inject BambuLabService BambuLabService
@using FilamentTracker.Models
@implements IDisposable

<PageTitle>Filament Inventory</PageTitle>

<div class="shell">
    <aside class="sidebar">
        <div class="sidebarTitle">Filament Tracker</div>
        <div class="sidebarSub">Navigation</div>
        <div class="sidebarButtons">
            <button class="navbtn nav-inventory @(currentPage == "inventory" ? "active" : "")" @onclick='() => SetPage("inventory")'>
                <span class="navicon">📦</span> Inventory
            </button>
            <button class="navbtn nav-add @(currentPage == "add" ? "active" : "")" @onclick='() => SetPage("add")'>
                <span class="navicon">➕</span> Add Filament
            </button>
            <button class="navbtn nav-spools @(currentPage == "spools" ? "active" : "")" @onclick='() => SetPage("spools")'>
                <span class="navicon">🔁</span> Spools
            </button>
            <button class="navbtn nav-calculator @(currentPage == "calculator" ? "active" : "")" @onclick='() => SetPage("calculator")'>
                <span class="navicon">💰</span> Calculator
            </button>
            <button class="navbtn nav-mqtt @(currentPage == "mqtt" ? "active" : "")" @onclick='() => SetPage("mqtt")'>
                <span class="navicon">📡</span> MQTT
            </button>
            <button class="navbtn nav-printer @(currentPage == "printer" ? "active" : "")" @onclick='() => SetPage("printer")'>
                <span class="navicon">🖨️</span> Printer
            </button>
            <button class="navbtn nav-ams @(currentPage == "ams" ? "active" : "")" @onclick='() => SetPage("ams")'>
                <span class="navicon">🗄️</span> AMS
            </button>
            <button class="navbtn nav-help @(currentPage == "help" ? "active" : "")" @onclick='() => SetPage("help")'>
                <span class="navicon">💡</span> Help
            </button>
            <button class="navbtn nav-settings @(currentPage == "settings" ? "active" : "")" @onclick='() => SetPage("settings")'>
                <span class="navicon">⚙️</span> Settings
            </button>
        </div>
    </aside>

    <main class="contentArea">
        <section class="liveStripCard">
            <div class="liveStripHeader">
                <div><strong>🖨️ Live View</strong></div>
                <div class="liveStripSub">Ready for multiple printers</div>
            </div>
            @if (_printers.Any(p => p.Enabled))
            {
                <div class="liveStripGrid">
                    @foreach (var printer in _printers.Where(p => p.Enabled))
                    {
                        var status = _printerStatuses.GetValueOrDefault(printer.Id);
                        var isConnected = BambuLabService.IsPrinterConnected(printer.Id);
                        var isPrinting = status?.IsPrinting == true;

                        <div class="livePrinterCard @(isPrinting ? "printing" : isConnected ? "connected" : "offline")">
                            <div class="livePrinterTop">
                                <div class="livePrinterName">🖨️ @printer.Name</div>
                                <div class="livePrinterState">@(isPrinting ? "Printing" : isConnected ? "Idle" : "Offline")</div>
                            </div>

                            @if (isPrinting && status != null)
                            {
                                <div class="miniProgressRow">
                                    <div class="miniProgressBar"><div class="miniProgressFill" style="@($"width:{status.Progress}%")"></div></div>
                                    <div class="miniProgressPct">@status.Progress%</div>
                                </div>
                                <div class="liveMiniGrid">
                                    <div class="miniMetric">🌡️ Nozzle: @status.NozzleTemperature°C</div>
                                    <div class="miniMetric">🛏️ Bed: @status.BedTemperature°C</div>
                                    <div class="miniMetric">📏 Layer: @status.CurrentLayer/@status.TotalLayers</div>
                                    <div class="miniMetric">⏳ Remaining: @status.TimeRemaining</div>
                                    <div class="miniMetric">🎯 ETA: @GetEstimatedCompletionTime(status.TimeRemaining)</div>
                                </div>
                            }
                            else if (isConnected && status != null)
                            {
                                <div class="liveMiniGrid idleCenter">
                                    <div class="miniMetric">🌡️ Nozzle: @status.NozzleTemperature°C</div>
                                    <div class="miniMetric">🛏️ Bed: @status.BedTemperature°C</div>
                                    <div class="miniMetric idleSleep">💤 zZZZ</div>
                                </div>
                            }
                            else
                            {
                                <div class="miniMeta">Not connected</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="miniMeta">No enabled printers yet. Configure printers in `MQTT`.</div>
            }
        </section>

        <style>
            .shell {
                display: grid;
                grid-template-columns: 230px minmax(0, 1fr);
                gap: 12px;
                align-items: start;
            }

            .sidebar {
                position: sticky;
                top: 12px;
                border: 1px solid var(--border);
                border-radius: 12px;
                background: var(--panel);
                padding: 12px;
            }

            .sidebarTitle {
                font-weight: 900;
                font-size: 16px;
            }

            .sidebarSub {
                color: var(--muted);
                font-size: 12px;
                margin-top: 2px;
                margin-bottom: 10px;
            }

            .sidebarButtons {
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .sidebarButtons .navbtn {
                width: 100%;
                justify-content: flex-start;
                position: relative;
                overflow: hidden;
                isolation: isolate;
                transition: transform 0.18s ease, box-shadow 0.22s ease, border-color 0.22s ease;
            }

            .sidebarButtons .navbtn::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg, rgba(192, 132, 252, 0.24), rgba(236, 72, 153, 0.2));
                transform: translateY(100%);
                transition: transform 0.28s ease;
                z-index: 0;
            }

            .sidebarButtons .navbtn:hover::before,
            .sidebarButtons .navbtn.active::before {
                transform: translateY(0);
            }

            .sidebarButtons .navbtn:hover {
                transform: translateY(-1px);
            }

            .sidebarButtons .navbtn.active {
                box-shadow: 0 0 10px #c084fc99, 0 0 18px #ec489922;
                border-color: #c084fc;
            }

            .sidebarButtons .navbtn > * {
                position: relative;
                z-index: 1;
            }

            .sidebarButtons .navicon {
                width: 24px;
                height: 24px;
                border-radius: 7px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                margin-right: 8px;
                font-size: 14px;
            }

            .nav-inventory .navicon { background: linear-gradient(135deg, #06b6d4, #3b82f6); }
            .nav-add .navicon { background: linear-gradient(135deg, #22c55e, #10b981); }
            .nav-spools .navicon { background: linear-gradient(135deg, #f59e0b, #ef4444); }
            .nav-calculator .navicon { background: linear-gradient(135deg, #8b5cf6, #6366f1); }
            .nav-mqtt .navicon { background: linear-gradient(135deg, #14b8a6, #0ea5e9); }
            .nav-printer .navicon { background: linear-gradient(135deg, #3b82f6, #2563eb); }
            .nav-ams .navicon { background: linear-gradient(135deg, #f97316, #fb7185); }
            .nav-help .navicon { background: linear-gradient(135deg, #a855f7, #ec4899); }
            .nav-settings .navicon { background: linear-gradient(135deg, #64748b, #475569); }

            .contentArea {
                min-width: 0;
            }

            .liveStripCard {
                border: 1px solid var(--border);
                border-radius: 12px;
                background: var(--panel);
                padding: 10px;
                margin-bottom: 12px;
            }

            .liveStripHeader {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 8px;
                gap: 10px;
            }

            .liveStripSub {
                font-size: 12px;
                color: var(--muted);
            }

            .liveStripGrid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 8px;
            }

            .livePrinterCard {
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 8px;
                background: rgba(255, 255, 255, 0.02);
            }

            .nebula .livePrinterCard {
                background: var(--panel2);
            }

            .livePrinterCard.connected {
                border-color: rgba(16, 185, 129, 0.35);
            }

            .livePrinterCard.printing {
                border-color: rgba(59, 130, 246, 0.45);
            }

            .livePrinterTop {
                display: flex;
                justify-content: space-between;
                gap: 8px;
                align-items: center;
            }

            .livePrinterName {
                font-weight: 800;
                font-size: 13px;
            }

            .livePrinterState {
                color: var(--muted);
                font-size: 12px;
                white-space: nowrap;
            }

            .miniProgressRow {
                display: grid;
                grid-template-columns: 1fr auto;
                gap: 8px;
                align-items: center;
                margin-top: 6px;
            }

            .miniProgressBar {
                height: 8px;
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.08);
                overflow: hidden;
                border: 1px solid var(--border);
            }

            .miniProgressPct {
                font-size: 12px;
                font-weight: 800;
                color: #60a5fa;
                min-width: 36px;
                text-align: right;
            }

            .miniProgressFill {
                height: 100%;
                background: linear-gradient(90deg, #3b82f6, #6366f1);
            }

            .liveMiniGrid {
                display: flex;
                flex-wrap: wrap;
                gap: 6px;
                margin-top: 7px;
            }

            .liveMiniGrid.idleCenter {
                justify-content: center;
            }

            .miniMetric {
                font-size: 11px;
                color: var(--muted);
                border: 1px solid var(--border);
                border-radius: 999px;
                padding: 3px 8px;
                background: rgba(255, 255, 255, 0.02);
            }

            .idleSleep {
                border-color: rgba(139, 92, 246, 0.45);
                color: #c4b5fd;
                animation: idleSleepPulse 1.8s ease-in-out infinite;
                transform-origin: center;
            }

            @@keyframes idleSleepPulse {
                0% {
                    transform: translateY(0) scale(1);
                    box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.0);
                    opacity: 0.9;
                }
                50% {
                    transform: translateY(-1px) scale(1.04);
                    box-shadow: 0 0 0 5px rgba(139, 92, 246, 0.12);
                    opacity: 1;
                }
                100% {
                    transform: translateY(0) scale(1);
                    box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.0);
                    opacity: 0.9;
                }
            }

            .miniMeta {
                margin-top: 6px;
                font-size: 12px;
                color: var(--muted);
            }

            @@media (max-width: 980px) {
                .shell {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    position: static;
                }
            }
        </style>
    @if (currentPage == "inventory")
    {
        <InventoryPage/>
    }
    else if (currentPage == "add")
    {
        <AddFilamentPage/>
    }
    else if (currentPage == "spools")
    {
        <SpoolsPage/>
    }
    else if (currentPage == "calculator")
    {
        <PrintCalculatorPage/>
    }
    else if (currentPage == "mqtt")
    {
        <MqttPage/>
    }
    else if (currentPage == "help")
    {
        <HelpPage/>
    }
    else if (currentPage == "settings")
    {
        <SettingsPage/>
    }
    else if (currentPage == "ams")
    {
        <AMSPage/>
    }
    else if (currentPage == "printer")
    {
        <PrinterPage/>
    }
    </main>
</div>

@code {
    private string currentPage = "inventory";
    private List<Printer> _printers = [];
    private Dictionary<int, PrintStatus> _printerStatuses = [];
    private string _userTimeZoneId = "Europe/Copenhagen";

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to BambuLab status updates (now includes printer ID)
        BambuLabService.OnStatusUpdated += HandleStatusUpdate;

        _printers = await FilamentService.GetAllPrintersAsync();
        _printerStatuses = BambuLabService.GetAllPrinterStatuses();

        // Load user's timezone setting
        try
        {
            var settings = await FilamentService.GetSettingsAsync();
            _userTimeZoneId = settings.TimeZoneId;
        }
        catch
        {
            // Fallback to Copenhagen if settings can't be loaded
            _userTimeZoneId = "Europe/Copenhagen";
        }
    }

    private void HandleStatusUpdate(int printerId, PrintStatus? status)
    {
        if (status == null) return;

        try
        {
            InvokeAsync(() =>
            {
                try
                {
                    _printerStatuses[printerId] = status;
                    StateHasChanged();
                }
                catch
                {
                    /* component may have been disposed */
                }
            });
        }
        catch
        {
            /* swallow to protect the MQTT background thread */
        }
    }


    private void SetPage(string page)
    {
        currentPage = page;
    }

    private string TruncateFileName(string fileName)
    {
        if (fileName.Length <= 20)
            return fileName;

        return fileName.Substring(0, 17) + "...";
    }

    private bool IsLongFileName(string fileName)
    {
        if (string.IsNullOrEmpty(fileName)) return false;
        // Treat names longer than 28 characters as long and enable scrolling
        return fileName.Length > 28;
    }

    /// <summary>
    ///     Converts a Wi-Fi signal string like "-59dBm" to a bar count 0-5.
    ///     ≥ -50 → 5, -51.-60 → 4, -61.-70 → 3, -71.-80 → 2, -81.-90 → 1, &lt; -90 → 0
    /// </summary>
    private static int GetWifiBars(string? signal)
    {
        if (string.IsNullOrEmpty(signal)) return 0;
        var numStr = signal.Replace("dBm", "").Trim();
        if (!int.TryParse(numStr, out var dbm)) return 0;
        if (dbm >= -50) return 5;
        if (dbm >= -60) return 4;
        if (dbm >= -70) return 3;
        if (dbm >= -80) return 2;
        if (dbm >= -90) return 1;
        return 0;
    }

    /// <summary>
    ///     Calculates the estimated completion time based on time remaining.
    ///     Parses "2h 34m" format and adds to current time, converting to user's local timezone.
    ///     Automatically handles daylight saving time transitions.
    /// </summary>
    private string GetEstimatedCompletionTime(string timeRemaining)
    {
        if (string.IsNullOrEmpty(timeRemaining))
            return "--:--";

        try
        {
            // Parse format like "2h 34m" or "45m" or "1h 5m"
            var hours = 0;
            var minutes = 0;

            var parts = timeRemaining.ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            foreach (var part in parts)
            {
                if (part.EndsWith("h"))
                {
                    if (int.TryParse(part.Replace("h", ""), out var h))
                        hours = h;
                }
                else if (part.EndsWith("m"))
                {
                    if (int.TryParse(part.Replace("m", ""), out var m))
                        minutes = m;
                }
            }

            // Calculate ETA in server time
            var serverEta = DateTime.Now.AddHours(hours).AddMinutes(minutes);

            // Convert to user's timezone (automatically handles DST)
            TimeZoneInfo userTimeZone;
            try
            {
                userTimeZone = TimeZoneInfo.FindSystemTimeZoneById(_userTimeZoneId);
            }
            catch
            {
                // Fallback to Copenhagen if timezone is invalid
                userTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Europe/Copenhagen");
            }

            var localEta = TimeZoneInfo.ConvertTime(serverEta, userTimeZone);

            // Format as "Today at HH:mm" or "Tomorrow at HH:mm"
            // Compare dates in user's timezone
            var localNow = TimeZoneInfo.ConvertTime(DateTime.Now, userTimeZone);
            var isToday = localEta.Date == localNow.Date;
            var isTomorrow = localEta.Date == localNow.Date.AddDays(1);

            if (isToday)
                return $"Today at {localEta:HH:mm}";
            else if (isTomorrow)
                return $"Tomorrow at {localEta:HH:mm}";
            else
                return localEta.ToString("ddd at HH:mm");
        }
        catch
        {
            return "--:--";
        }
    }

    public void Dispose()
    {
        BambuLabService.OnStatusUpdated -= HandleStatusUpdate;
    }

}
